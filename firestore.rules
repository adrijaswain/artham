rules_version = '2';

// Artham Firestore security rules.
//
// User profiles live at `users/{uid}` and hold intake data, the evidence
// vault, chat history and derived context. Each document must only ever be
// read or written by the signed-in user it belongs to.
//
// Deploy with:  firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
